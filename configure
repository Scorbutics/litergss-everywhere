#!/bin/sh
#
# Configure script for LiteRGSS-Everywhere Build System
# Generates a Makefile for building LiteRGSS with optional Docker support
#

set -e

# Get the root directory
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure cmake/core symlink exists (points to ruby-for-android submodule)
if [ ! -d "$ROOT_DIR/cmake/core" ]; then
	echo "Creating symlink: $ROOT_DIR/cmake/core -> external/ruby-for-android/cmake/core"
	ln -s ../external/ruby-for-android/cmake/core "$ROOT_DIR/cmake/core"
fi

# Verify submodule is initialized
if [ ! -f "$ROOT_DIR/external/ruby-for-android/CMakeLists.txt" ]; then
	echo "Error: ruby-for-android submodule not initialized"
	echo "Run: git submodule update --init --recursive"
	exit 1
fi

# Default values
USE_DOCKER=1
TOOLCHAIN_PARAMS_LIST=""
PREFIX="/usr/local"
BUILD_DIR="build"
TARGET_DIR="target"
EXTRA_CMAKE_ARGS=""

# Parse command-line arguments
show_help() {
	cat << EOF
Usage: ./configure [OPTIONS]

Configuration Options:
  --without-docker          Build without Docker (requires local toolchain setup)
  --with-docker             Build with Docker (default)
  --with-toolchain-params=FILE
                            Specify toolchain parameters file (repeatable for multi-ABI)
                            (default: toolchain-params/arm64-v8a-android-toolchain.params)
  --enable-shared           Build shared libraries (.so files)
  --enable-static           Build static libraries (.a files) - default
  --enable-debug            Build with debug symbols and logging (CMAKE_BUILD_TYPE=Debug)
  --enable-release          Build with optimizations (CMAKE_BUILD_TYPE=Release)
  --prefix=PREFIX           Installation prefix (default: /usr/local)
  --build-dir=DIR           Build directory (default: build)
  --target-dir=DIR          Output directory for artifacts (default: target)
  --help                    Display this help message

Examples:
  ./configure
  ./configure --enable-shared
  ./configure --enable-debug
  ./configure --without-docker --with-toolchain-params=toolchain-params/x86_64-linux-toolchain.params --enable-static
  ./configure --with-toolchain-params=toolchain-params/x86_64-android-toolchain.params --enable-shared --enable-debug

  Multi-ABI Android build (produces a single AAR with both ABIs):
  ./configure --with-toolchain-params=toolchain-params/arm64-v8a-android-toolchain.params \\
              --with-toolchain-params=toolchain-params/x86_64-android-toolchain.params

  CI/CD cross-platform builds (separate target dirs to avoid collisions):
  ./configure --target-dir=target-android --build-dir=build-android \\
              --with-toolchain-params=toolchain-params/arm64-v8a-android-toolchain.params \\
              --with-toolchain-params=toolchain-params/x86_64-android-toolchain.params
  make && make install
  ./configure --target-dir=target-linux --build-dir=build-linux --without-docker \\
              --with-toolchain-params=toolchain-params/x86_64-linux-toolchain.params
  make && make install

Environment Variables:
  ANDROID_NDK              Path to Android NDK (for Android builds)

EOF
	exit 0
}

# Parse options
while [ $# -gt 0 ]; do
	case "$1" in
		--without-docker)
			USE_DOCKER=0
			shift
			;;
		--with-docker)
			USE_DOCKER=1
			shift
			;;
		--with-toolchain-params=*)
			TOOLCHAIN_PARAMS_LIST="${TOOLCHAIN_PARAMS_LIST:+$TOOLCHAIN_PARAMS_LIST }${1#*=}"
			shift
			;;
		--enable-shared)
			EXTRA_CMAKE_ARGS="$EXTRA_CMAKE_ARGS -DBUILD_SHARED_LIBS=ON"
			shift
			;;
		--enable-static)
			EXTRA_CMAKE_ARGS="$EXTRA_CMAKE_ARGS -DBUILD_SHARED_LIBS=OFF"
			shift
			;;
		--enable-debug)
			EXTRA_CMAKE_ARGS="$EXTRA_CMAKE_ARGS -DCMAKE_BUILD_TYPE=Debug"
			shift
			;;
		--enable-release)
			EXTRA_CMAKE_ARGS="$EXTRA_CMAKE_ARGS -DCMAKE_BUILD_TYPE=Release"
			shift
			;;
		--prefix=*)
			PREFIX="${1#*=}"
			shift
			;;
		--build-dir=*)
			BUILD_DIR="${1#*=}"
			shift
			;;
		--target-dir=*)
			TARGET_DIR="${1#*=}"
			shift
			;;
		--help|-h)
			show_help
			;;
		*)
			echo "Error: Unknown option '$1'"
			echo "Run './configure --help' for usage information"
			exit 1
			;;
	esac
done

# Apply default if no toolchain params specified
if [ -z "$TOOLCHAIN_PARAMS_LIST" ]; then
	TOOLCHAIN_PARAMS_LIST="toolchain-params/arm64-v8a-android-toolchain.params"
fi

# Validate toolchain files and extract ABI names
TOOLCHAIN_COUNT=0
TOOLCHAIN_ABI_LIST=""
for tp in $TOOLCHAIN_PARAMS_LIST; do
	if [ ! -f "$ROOT_DIR/$tp" ]; then
		echo "Error: Toolchain parameters file not found: $tp"
		echo "Available toolchain files:"
		ls -1 "$ROOT_DIR"/toolchain-params/*.params 2>/dev/null || echo "  (none found)"
		exit 1
	fi
	TOOLCHAIN_COUNT=$((TOOLCHAIN_COUNT + 1))
	ABI=$(grep -o 'DANDROID_ABI=[^ ]*' "$ROOT_DIR/$tp" 2>/dev/null | sed 's/DANDROID_ABI=//')
	if [ -n "$ABI" ]; then
		TOOLCHAIN_ABI_LIST="${TOOLCHAIN_ABI_LIST:+$TOOLCHAIN_ABI_LIST }$ABI"
	else
		TOOLCHAIN_ABI_LIST="${TOOLCHAIN_ABI_LIST:+$TOOLCHAIN_ABI_LIST }generic"
	fi
done

# Multi-ABI only supported for Android toolchains
if [ $TOOLCHAIN_COUNT -gt 1 ]; then
	for tp in $TOOLCHAIN_PARAMS_LIST; do
		if ! grep -q "DANDROID_ABI=" "$ROOT_DIR/$tp"; then
			echo "Error: Multi-ABI builds only supported for Android toolchains"
			echo "  Non-Android toolchain: $tp"
			exit 1
		fi
	done
fi

# Check Docker availability if Docker build is requested
if [ $USE_DOCKER -eq 1 ]; then
	if ! command -v docker >/dev/null 2>&1; then
		echo "Error: Docker is not installed or not in PATH"
		echo "Install Docker or use --without-docker flag"
		exit 1
	fi

	if ! docker info >/dev/null 2>&1; then
		echo "Error: Docker daemon is not running"
		echo "Start Docker or use --without-docker flag"
		exit 1
	fi

	echo "Docker build: enabled"
else
	echo "Docker build: disabled (local build)"

	# Check for required tools for local build
	for tool in cmake make; do
		if ! command -v $tool >/dev/null 2>&1; then
			echo "Error: Required tool '$tool' not found in PATH"
			exit 1
		fi
	done

	# Ruby 3.0.0+ is needed by the 'make install' step (via ruby-for-android)
	if ! command -v ruby >/dev/null 2>&1; then
		echo "Warning: Ruby not found in PATH (required for ruby-for-android build)"
		echo "Install Ruby 3.0.0+ on the host system"
	fi

	# Check for Android NDK if any toolchain is an Android build
	IS_ANDROID=0
	for tp in $TOOLCHAIN_PARAMS_LIST; do
		if grep -q "DANDROID_ABI=" "$ROOT_DIR/$tp"; then IS_ANDROID=1; break; fi
	done
	if [ $IS_ANDROID -eq 1 ]; then
		if [ -z "$ANDROID_NDK" ]; then
			NDK_BASE="$HOME/Android/Sdk/ndk"
			if [ -d "$NDK_BASE" ]; then
				ANDROID_NDK="$NDK_BASE/$(ls "$NDK_BASE" | tail -n 1)"
			fi
		fi

		if [ ! -d "$ANDROID_NDK" ]; then
			echo "Error: ANDROID_NDK not set or directory not found"
			echo "Set ANDROID_NDK environment variable or install Android NDK"
			exit 1
		fi

		echo "Android NDK: $ANDROID_NDK"
	fi
fi

if [ $TOOLCHAIN_COUNT -eq 1 ]; then
	echo "Toolchain: $TOOLCHAIN_PARAMS_LIST"
else
	echo "Toolchains ($TOOLCHAIN_COUNT):"
	for tp in $TOOLCHAIN_PARAMS_LIST; do
		echo "  - $tp"
	done
	echo "ABIs: $TOOLCHAIN_ABI_LIST"
fi
echo "Prefix: $PREFIX"
echo "Build directory: $BUILD_DIR"
echo "Target directory: $TARGET_DIR"
if echo "$EXTRA_CMAKE_ARGS" | grep -q "BUILD_SHARED_LIBS=ON"; then
	echo "Build mode: Shared libraries (.so)"
elif echo "$EXTRA_CMAKE_ARGS" | grep -q "BUILD_SHARED_LIBS=OFF"; then
	echo "Build mode: Static libraries (.a)"
else
	echo "Build mode: Static libraries (.a) - default"
fi
if echo "$EXTRA_CMAKE_ARGS" | grep -q "CMAKE_BUILD_TYPE=Debug"; then
	echo "Build type: Debug (with debug symbols and logging)"
elif echo "$EXTRA_CMAKE_ARGS" | grep -q "CMAKE_BUILD_TYPE=Release"; then
	echo "Build type: Release (optimized)"
else
	echo "Build type: Default (unspecified)"
fi

# Generate Makefile
echo "Generating Makefile..."

cat > "$ROOT_DIR/Makefile" << 'MAKEFILE_EOF'
# Generated Makefile - DO NOT EDIT
# Run ./configure to regenerate this file

# Use bash instead of sh for bash-specific syntax (e.g., here-strings <<<)
SHELL := /bin/bash

# Configuration
USE_DOCKER=@USE_DOCKER@
TOOLCHAIN_PARAMS_LIST=@TOOLCHAIN_PARAMS_LIST@
TOOLCHAIN_ABI_LIST=@TOOLCHAIN_ABI_LIST@
TOOLCHAIN_COUNT=@TOOLCHAIN_COUNT@
PREFIX=@PREFIX@
BUILD_DIR=@BUILD_DIR@
TARGET_DIR=@TARGET_DIR@
ROOT_DIR=@ROOT_DIR@
EXTRA_CMAKE_ARGS=@EXTRA_CMAKE_ARGS@
PROJECT_NAME=litergss-everywhere
CONTAINER=$(PROJECT_NAME)_dev
DOCKER_WORKDIR=/opt/current/src
DOCKER_BUILD_DIR=/opt/current/build

.PHONY: all build configure-cmake install test publish-kmp clean clean-libs clean-downloads clean-artifacts clean-all help sync docker-init docker-start docker-check-running docker-check-volume docker-sync android-example android-example-build android-example-install docker-deps-image download-deps

# Default target
all: build

help:
	@echo "Available targets:"
	@echo "  all (default)      - Build the project"
	@echo "  build              - Build the project (same as 'all')"
	@echo "  sync               - Force sync of source files to Docker (Docker mode only)"
	@echo "  configure-cmake    - Run CMake configuration"
	@echo "  install            - Install/export build artifacts and publish KMP module"
	@echo "  test               - Run smoke tests (native builds only, skipped when cross-compiling)"
	@echo "  publish-kmp        - Publish KMP module to Maven Local (called by install)"
	@echo "  android-example-build - Build the Android example app (assembleDebug)"
	@echo "  android-example-install - Build and install the Android example app on device"
	@echo "  android-example    - Alias for android-example-install"
	@echo "  clean              - Clean build artifacts (keeps downloads)"
	@echo "  clean-libs         - Clean library build directories"
	@echo "  clean-downloads    - Remove downloaded source archives"
	@echo "  clean-artifacts    - Remove output directory ($(TARGET_DIR))"
	@echo "  clean-all          - Clean everything (libs + downloads + artifacts)"
	@echo "  clean-rgss_fat_library - Clean the fat library and JNI output directories"
	@echo "  clean-<package>    - Clean specific package (e.g., clean-ruby-for-android)"
	@echo "  logs-<package>-<step> - Show log for package build step (download/configure/build/install)"
	@echo ""
	@echo "Dependency caching:"
	@echo "  docker-deps-image  - Generate and build Docker image with pre-cached dependencies"
	@echo "  download-deps      - Pre-download all dependencies locally (no Docker needed)"

# ============================================================================
# Dependency Caching Targets (work in both Docker and Local modes)
# ============================================================================

# Generate Dockerfile.deps with pre-cached dependencies and build the image
docker-deps-image:
	@echo "Generating Dockerfile with cached dependencies..."
	@cmake \
		-DDEPS_DIR=$(ROOT_DIR)/cmake/litergss-app/dependencies \
		-DBASE_DOCKERFILE=$(ROOT_DIR)/docker/Dockerfile \
		-DOUTPUT_DIR=$(ROOT_DIR)/build/docker \
		-P $(ROOT_DIR)/cmake/docker/GenerateDockerfile.cmake
	@echo ""
	@echo "Building Docker image with cached dependencies..."
	docker build -f $(ROOT_DIR)/build/docker/Dockerfile.deps -t litergss-deps $(ROOT_DIR)/docker/
	@echo ""
	@echo "Done! Image tagged as: litergss-deps"
	@echo "To use it, update docker-compose.yml to reference 'litergss-deps' instead of building from docker/"

# Pre-download all dependencies locally (for non-Docker or offline builds)
download-deps:
	@echo "Pre-downloading all dependencies..."
	@cmake \
		-DDEPS_DIR=$(ROOT_DIR)/cmake/litergss-app/dependencies \
		-DDOWNLOAD_DIR=$(ROOT_DIR)/$(BUILD_DIR)/downloads \
		-DGIT_CACHE_DIR=$(ROOT_DIR)/$(BUILD_DIR)/git-cache \
		-P $(ROOT_DIR)/cmake/docker/PreloadDeps.cmake

ifeq ($(USE_DOCKER),1)

# ============================================================================
# Docker Mode Targets
# ============================================================================

# Check if container is running
docker-check-running:
	@if ! docker ps --filter "name=$(CONTAINER)" --format "{{.Names}}" 2>/dev/null | grep -q "^$(CONTAINER)$$"; then \
		echo "Container $(CONTAINER) is not running"; \
		exit 1; \
	fi

# Check if volume exists
docker-check-volume:
	@if ! docker volume ls --format "{{.Name}}" 2>/dev/null | grep -q "^$(PROJECT_NAME)_currentdata$$"; then \
		echo "Volume $(PROJECT_NAME)_currentdata does not exist, will create"; \
	fi

# Sync sources to Docker volume
docker-sync: docker-check-volume
	@echo "Synchronizing source files to Docker volume..."
	@if docker compose run --rm --remove-orphans init >/dev/null 2>&1; then \
		echo "Source synchronization complete"; \
	else \
		echo "Error: Failed to synchronize sources"; \
		exit 1; \
	fi

# Force sync (removes init containers and performs fresh sync)
sync:
	@echo "Forcing fresh synchronization of source files..."
	@echo "Removing any orphaned init containers..."
	@docker compose rm -f -s -v init 2>/dev/null || true
	@$(MAKE) docker-sync

# Start the development container
docker-start:
	@echo "Starting development container..."
	@if docker compose up -d litergss-dev 2>&1 | grep -q "Started\|Running"; then \
		echo "Development container started"; \
	else \
		if docker ps --filter "name=$(CONTAINER)" --format "{{.Names}}" 2>/dev/null | grep -q "^$(CONTAINER)$$"; then \
			echo "Development container already running"; \
		else \
			echo "Error: Failed to start development container"; \
			exit 1; \
		fi \
	fi
	@echo "Waiting for container to be ready..."
	@max_attempts=30; attempt=0; \
	while [ $$attempt -lt $$max_attempts ]; do \
		if docker exec $(CONTAINER) echo "ready" >/dev/null 2>&1; then \
			echo "Container is ready"; \
			break; \
		fi; \
		attempt=$$((attempt + 1)); \
		sleep 1; \
	done; \
	if [ $$attempt -eq $$max_attempts ]; then \
		echo "Error: Container failed to become ready"; \
		exit 1; \
	fi

# Initialize Docker environment (sync + start)
docker-init:
	@if docker ps --filter "name=$(CONTAINER)" --format "{{.Names}}" 2>/dev/null | grep -q "^$(CONTAINER)$$"; then \
		echo "Container already running, skipping sync"; \
	else \
		$(MAKE) docker-sync; \
		$(MAKE) docker-start; \
	fi

# CMake configuration in Docker
configure-cmake: docker-init
	@echo "Configuring with CMake (Docker mode)..."
	@set -e; \
	toolchains=($(TOOLCHAIN_PARAMS_LIST)); \
	abis=($(TOOLCHAIN_ABI_LIST)); \
	for i in $${!toolchains[@]}; do \
		tp=$${toolchains[$$i]}; \
		abi=$${abis[$$i]}; \
		if [ $(TOOLCHAIN_COUNT) -eq 1 ]; then \
			build_dir=$(DOCKER_BUILD_DIR); \
		else \
			build_dir=$(DOCKER_BUILD_DIR)-$$abi; \
		fi; \
		echo ""; \
		echo "=== Configuring ABI: $$abi ($$tp) ==="; \
		echo "Build directory: $$build_dir"; \
		docker exec $(CONTAINER) mkdir -p $$build_dir; \
		docker exec $(CONTAINER) sh -c "cd $$build_dir && \
			export SOURCE_DIR=$(DOCKER_WORKDIR) && \
			TOOLCHAIN_PARAMS_FILE=\$$SOURCE_DIR/$$tp && \
			if [ ! -f \"\$$TOOLCHAIN_PARAMS_FILE\" ]; then \
				echo \"Error: Toolchain parameters file not found: \$$TOOLCHAIN_PARAMS_FILE\"; \
				exit 1; \
			fi && \
			echo \"Using toolchain parameters from: \$$TOOLCHAIN_PARAMS_FILE\" && \
			DEPS_CACHE_ARGS=\"\" && \
			if [ -d /opt/deps-cache/downloads ]; then \
				echo \"Using pre-cached dependencies from /opt/deps-cache/downloads\"; \
				DEPS_CACHE_ARGS=\"-DBUILD_DOWNLOAD_DIR=/opt/deps-cache/downloads\"; \
			fi && \
			rm -f CMakeCache.txt && \
			if grep -q \"DANDROID_ABI=\" \"\$$TOOLCHAIN_PARAMS_FILE\"; then \
				NDK_BASE=/opt/android-ndk && \
				export ANDROID_NDK=\$$NDK_BASE && \
				if [ ! -d \"\$$ANDROID_NDK\" ]; then \
					echo \"Error: ANDROID_NDK not found\"; \
					exit 1; \
				fi && \
				echo \"Android NDK: \$$ANDROID_NDK\" && \
				cmake \$$(cat \$$TOOLCHAIN_PARAMS_FILE) \
					-DCMAKE_TOOLCHAIN_FILE=\$$ANDROID_NDK/build/cmake/android.toolchain.cmake \
					-DTOOLCHAIN_FILE=\$$TOOLCHAIN_PARAMS_FILE \
					\$$DEPS_CACHE_ARGS \
					$(EXTRA_CMAKE_ARGS) \
					\$$SOURCE_DIR; \
			else \
				cmake \$$(cat \$$TOOLCHAIN_PARAMS_FILE) \
					-DTOOLCHAIN_FILE=\$$TOOLCHAIN_PARAMS_FILE \
					\$$DEPS_CACHE_ARGS \
					$(EXTRA_CMAKE_ARGS) \
					\$$SOURCE_DIR; \
			fi"; \
	done

# Build in Docker
build: configure-cmake
	@echo "Building project (Docker mode)..."
	@set -e; \
	abis=($(TOOLCHAIN_ABI_LIST)); \
	for i in $${!abis[@]}; do \
		abi=$${abis[$$i]}; \
		if [ $(TOOLCHAIN_COUNT) -eq 1 ]; then \
			build_dir=$(DOCKER_BUILD_DIR); \
		else \
			build_dir=$(DOCKER_BUILD_DIR)-$$abi; \
		fi; \
		echo ""; \
		echo "=== Building ABI: $$abi ==="; \
		docker exec $(CONTAINER) cmake --build $$build_dir; \
	done

test: build
	@echo "Running tests (Docker mode)..."
	@set -e; \
	abis=($(TOOLCHAIN_ABI_LIST)); \
	for i in $${!abis[@]}; do \
		abi=$${abis[$$i]}; \
		if [ $(TOOLCHAIN_COUNT) -eq 1 ]; then \
			build_dir=$(DOCKER_BUILD_DIR); \
		else \
			build_dir=$(DOCKER_BUILD_DIR)-$$abi; \
		fi; \
		echo ""; \
		echo "=== Running tests for ABI: $$abi ==="; \
		docker exec $(CONTAINER) cmake --build $$build_dir --target rgss_smoke_test 2>/dev/null && \
			docker exec $(CONTAINER) ctest --test-dir $$build_dir --output-on-failure || \
			echo "  (smoke test not available for this configuration, skipping)"; \
	done

# Install/export from Docker
install: docker-check-running
	@echo "Exporting build artifacts from Docker..."
	@rm -rf $(TARGET_DIR)
	@mkdir -p $(TARGET_DIR)
	@# Export archives from each ABI build directory
	@set -e; \
	abis=($(TOOLCHAIN_ABI_LIST)); \
	for i in $${!abis[@]}; do \
		abi=$${abis[$$i]}; \
		if [ $(TOOLCHAIN_COUNT) -eq 1 ]; then \
			build_dir=$(DOCKER_BUILD_DIR); \
		else \
			build_dir=$(DOCKER_BUILD_DIR)-$$abi; \
		fi; \
		echo ""; \
		echo "=== Exporting artifacts for ABI: $$abi ==="; \
		BUILD_STAGING_DIR=$$(docker exec $(CONTAINER) grep -E "BUILD_STAGING_DIR:" $$build_dir/CMakeCache.txt 2>/dev/null | sed -E 's/.*=(.*)$$/\1/'); \
		if [ -z "$$BUILD_STAGING_DIR" ]; then \
			echo "Error: BUILD_STAGING_DIR not found in CMake cache for $$abi"; \
			exit 1; \
		fi; \
		echo "Staging directory: $$BUILD_STAGING_DIR"; \
		TARGET_ARCHIVES=$$(docker exec $(CONTAINER) grep -E "TARGET_ARCHIVES:" $$build_dir/CMakeCache.txt 2>/dev/null | sed -E 's/.*=(.*)$$/\1/'); \
		if [ -z "$$TARGET_ARCHIVES" ]; then \
			echo "Warning: No archives registered in TARGET_ARCHIVES for $$abi"; \
			docker exec $(CONTAINER) tar -czf - -C $$build_dir/target . 2>/dev/null | tar -xzf - -C $(TARGET_DIR) 2>/dev/null || true; \
		else \
			echo "Found registered archives: $$TARGET_ARCHIVES"; \
			FAILED=0; \
			IFS=';' read -ra ARCHIVES <<< "$$TARGET_ARCHIVES"; \
			for archive in "$${ARCHIVES[@]}"; do \
				if [ -z "$$archive" ]; then continue; fi; \
				ARCHIVE_PATH="$$BUILD_STAGING_DIR/$$archive"; \
				echo "Checking archive: $$archive"; \
				if docker exec $(CONTAINER) test -f "$$ARCHIVE_PATH"; then \
					echo "  Copying $$archive..."; \
					docker cp $(CONTAINER):"$$ARCHIVE_PATH" $(TARGET_DIR)/ 2>/dev/null || { echo "  Warning: Failed to copy $$archive"; FAILED=1; }; \
				else \
					echo "  ERROR: Archive not found: $$ARCHIVE_PATH"; \
					FAILED=1; \
				fi; \
			done; \
			if [ $$FAILED -eq 1 ]; then \
				echo "Error: One or more archives are missing or failed to copy"; \
				exit 1; \
			fi; \
		fi; \
	done
	@echo "Build artifacts exported to: ./$(TARGET_DIR)"
	@ls -lh $(TARGET_DIR)/*.zip 2>/dev/null | awk '{print "  " $$9 " (" $$5 ")"}' || echo "  No archives found"
	@$(MAKE) publish-kmp

# Publish KMP module to Maven Local
# This target builds .so wrappers for all configured ABIs, stages them into jniLibs,
# then publishes a single AAR containing all ABIs.
publish-kmp: docker-check-running
	@echo ""
	@echo "=========================================="
	@echo "Publishing KMP module to Maven Local..."
	@echo "=========================================="
	@# Clean stale jniLibs to avoid leftover ABIs from previous runs
	@rm -rf $(ROOT_DIR)/external/embedded-ruby-vm/kmp-publish/src/main/jniLibs
	@# Phase 1: Build .so wrapper and stage for each ABI
	@set -e; \
	abis=($(TOOLCHAIN_ABI_LIST)); \
	NDK_HOME=/opt/android-ndk/; \
	for i in $${!abis[@]}; do \
		abi=$${abis[$$i]}; \
		if [ $(TOOLCHAIN_COUNT) -eq 1 ]; then \
			build_dir=$(DOCKER_BUILD_DIR); \
		else \
			build_dir=$(DOCKER_BUILD_DIR)-$$abi; \
		fi; \
		echo ""; \
		echo "=== Staging ABI: $$abi ==="; \
		BUILD_STAGING_DIR=$$(docker exec $(CONTAINER) grep -E "BUILD_STAGING_DIR:" $$build_dir/CMakeCache.txt 2>/dev/null | sed -E 's/.*=(.*)$$/\1/'); \
		if [ -z "$$BUILD_STAGING_DIR" ]; then \
			echo "Error: BUILD_STAGING_DIR not found in CMake cache for $$abi"; \
			exit 1; \
		fi; \
		echo "Staging directory: $$BUILD_STAGING_DIR"; \
		TARGET_ARCH=$$(basename $$BUILD_STAGING_DIR | sed 's/-android$$//'); \
		echo "Detected target arch: $$TARGET_ARCH"; \
		case "$$TARGET_ARCH" in \
			arm64|arm64-v8a) ANDROID_ABI="arm64-v8a"; NDK_TRIPLE="aarch64-linux-android" ;; \
			arm|armeabi-v7a) ANDROID_ABI="armeabi-v7a"; NDK_TRIPLE="arm-linux-androideabi" ;; \
			x86_64)          ANDROID_ABI="x86_64"; NDK_TRIPLE="x86_64-linux-android" ;; \
			x86)             ANDROID_ABI="x86"; NDK_TRIPLE="i686-linux-android" ;; \
			*) echo "Error: Unknown target arch: $$TARGET_ARCH"; exit 1 ;; \
		esac; \
		echo "Android ABI: $$ANDROID_ABI"; \
		FAT_LIB_A="$$BUILD_STAGING_DIR/usr/local/lib/librgss_runtime.a"; \
		if ! docker exec $(CONTAINER) test -f "$$FAT_LIB_A"; then \
			echo "Warning: Fat library not found at $$FAT_LIB_A"; \
			echo "Skipping ABI $$abi"; \
			continue; \
		fi; \
		echo "Found fat library at: $$FAT_LIB_A"; \
		echo ""; \
		echo "--- Building shared library for $$ANDROID_ABI ---"; \
		echo "NDK: $$NDK_HOME"; \
		CMAKE_BUILD_DIR="$(DOCKER_BUILD_DIR)/kmp-publish-cmake/$$ANDROID_ABI"; \
		docker exec $(CONTAINER) mkdir -p "$$CMAKE_BUILD_DIR"; \
		docker exec $(CONTAINER) cmake \
			-S $(DOCKER_WORKDIR)/external/embedded-ruby-vm/kmp-publish/wrapper \
			-B "$$CMAKE_BUILD_DIR" \
			-DCMAKE_TOOLCHAIN_FILE="$$NDK_HOME/build/cmake/android.toolchain.cmake" \
			-DANDROID_ABI="$$ANDROID_ABI" \
			-DANDROID_PLATFORM=android-26 \
			-DANDROID_STL=c++_shared \
			-DTARGET_ABI="$$ANDROID_ABI" \
			-DTARGET_ARCH="$$TARGET_ARCH" \
			-DFAT_LIB_PATH="$$FAT_LIB_A" \
			-DCMAKE_BUILD_TYPE=RelWithDebInfo; \
		if ! docker exec $(CONTAINER) cmake --build "$$CMAKE_BUILD_DIR"; then \
			echo ""; \
			echo "✗ Failed to build librgss_runtime.so for $$ANDROID_ABI — aborting"; \
			exit 1; \
		fi; \
		echo ""; \
		echo "--- Staging .so into host jniLibs/$$ANDROID_ABI/ ---"; \
		JNILIBS_DIR="$(ROOT_DIR)/external/embedded-ruby-vm/kmp-publish/src/main/jniLibs/$$ANDROID_ABI"; \
		mkdir -p "$$JNILIBS_DIR"; \
		if ! docker cp $(CONTAINER):"$$CMAKE_BUILD_DIR/librgss_runtime.so" "$$JNILIBS_DIR/librgss_runtime.so"; then \
			echo "✗ librgss_runtime.so not found in build output — build likely failed"; \
			exit 1; \
		fi; \
		LIBCXX=$$(docker exec $(CONTAINER) find "$$NDK_HOME/toolchains/llvm/prebuilt" -path "*$$NDK_TRIPLE/libc++_shared.so" 2>/dev/null | head -1); \
		if [ -n "$$LIBCXX" ]; then \
			docker cp $(CONTAINER):"$$LIBCXX" "$$JNILIBS_DIR/libc++_shared.so"; \
		else \
			echo "Warning: libc++_shared.so not found for $$NDK_TRIPLE"; \
		fi; \
		echo "Staged files for $$ANDROID_ABI:"; \
		ls -lh "$$JNILIBS_DIR/"*.so 2>/dev/null | awk '{print "  " $$9 " (" $$5 ")"}'; \
	done
	@# Show all staged ABIs
	@echo ""
	@echo "All staged ABIs:"
	@for abi_dir in $(ROOT_DIR)/external/embedded-ruby-vm/kmp-publish/src/main/jniLibs/*/; do \
		abi_name=$$(basename "$$abi_dir"); \
		echo "  $$abi_name: $$(ls "$$abi_dir"*.so 2>/dev/null | wc -l) libraries"; \
	done
	@# Phase 2: Single Gradle publish with all ABIs
	@echo ""
	@echo "--- Publishing AAR with all ABIs ---"
	@docker exec $(CONTAINER) mkdir -p $(DOCKER_WORKDIR)/external/embedded-ruby-vm/kmp-publish
	@docker exec $(CONTAINER) mkdir -p $(DOCKER_WORKDIR)/external/embedded-ruby-vm/kmp
	@docker cp $(ROOT_DIR)/external/embedded-ruby-vm/kmp-publish/. $(CONTAINER):$(DOCKER_WORKDIR)/external/embedded-ruby-vm/kmp-publish/
	@docker cp $(ROOT_DIR)/external/embedded-ruby-vm/kmp/src $(CONTAINER):$(DOCKER_WORKDIR)/external/embedded-ruby-vm/kmp/
	@if [ -d "$(ROOT_DIR)/external/embedded-ruby-vm/kmp-publish/src" ]; then \
		docker cp $(ROOT_DIR)/external/embedded-ruby-vm/kmp-publish/src $(CONTAINER):$(DOCKER_WORKDIR)/external/embedded-ruby-vm/kmp-publish/; \
	fi
	@echo "sdk.dir=/opt/android-sdk" > $(ROOT_DIR)/external/embedded-ruby-vm/kmp-publish/local.properties
	@docker cp $(ROOT_DIR)/external/embedded-ruby-vm/kmp-publish/local.properties $(CONTAINER):$(DOCKER_WORKDIR)/external/embedded-ruby-vm/kmp-publish/local.properties
	@if docker exec $(CONTAINER) bash -c "cd $(DOCKER_WORKDIR)/external/embedded-ruby-vm/kmp-publish && ./gradlew clean publishToMavenLocal -PnativeLibraryName=rgss_runtime" 2>&1; then \
		echo ""; \
		echo "✓ KMP module published successfully!"; \
		echo "  Maven coordinates: com.scorbutics.rubyvm:kmp-publish-android:1.0.0-SNAPSHOT"; \
		echo ""; \
		echo "Copying Maven artifacts to host..."; \
		mkdir -p $(TARGET_DIR)/maven; \
		if docker exec $(CONTAINER) test -d /root/.m2/repository/com/scorbutics/rubyvm/kmp-publish-android; then \
			mkdir -p $(TARGET_DIR)/maven/com/scorbutics/rubyvm/; \
			docker cp $(CONTAINER):/root/.m2/repository/com/scorbutics/rubyvm/kmp-publish-android $(TARGET_DIR)/maven/com/scorbutics/rubyvm/; \
			echo "✓ Maven artifacts exported to: ./$(TARGET_DIR)/maven/"; \
			mkdir -p $(HOME)/.m2/repository/com/scorbutics/rubyvm/; \
			cp -r $(TARGET_DIR)/maven/com/scorbutics/rubyvm/kmp-publish-android $(HOME)/.m2/repository/com/scorbutics/rubyvm/; \
			echo "✓ Maven artifacts installed to: ~/.m2/repository/"; \
			echo ""; \
			echo "AAR contents:"; \
			unzip -l $(HOME)/.m2/repository/com/scorbutics/rubyvm/kmp-publish-android/1.0.0-SNAPSHOT/kmp-publish-android-1.0.0-SNAPSHOT.aar 2>/dev/null | grep -E "\.so|jni/" | awk '{print "  " $$4}'; \
		else \
			echo "Warning: Maven artifacts not found in container"; \
		fi; \
		echo ""; \
	else \
		echo ""; \
		echo "✗ Gradle publish failed - see error output above"; \
		exit 1; \
	fi

# Build Android example app
android-example-build: docker-check-running
	@echo ""
	@echo "=========================================="
	@echo "Building Android example app..."
	@echo "=========================================="
	@# Sync the example project to the container
	@docker exec $(CONTAINER) mkdir -p $(DOCKER_WORKDIR)/examples/android-integration
	@docker cp $(ROOT_DIR)/examples/android-integration/. $(CONTAINER):$(DOCKER_WORKDIR)/examples/android-integration/
	@# Set up local.properties for Android SDK
	@echo "sdk.dir=/opt/android-sdk" > $(ROOT_DIR)/examples/android-integration/local.properties
	@docker cp $(ROOT_DIR)/examples/android-integration/local.properties $(CONTAINER):$(DOCKER_WORKDIR)/examples/android-integration/local.properties
	@# Build the app
	@if docker exec $(CONTAINER) bash -c "cd $(DOCKER_WORKDIR)/examples/android-integration && ./gradlew assembleDebug" 2>&1; then \
		echo ""; \
		echo "✓ Android example app built successfully!"; \
		echo "  APK location (in container): $(DOCKER_WORKDIR)/examples/android-integration/app/build/outputs/apk/debug/app-debug.apk"; \
		docker exec $(CONTAINER) ls -lh $(DOCKER_WORKDIR)/examples/android-integration/app/build/outputs/apk/debug/app-debug.apk 2>/dev/null || true; \
		echo ""; \
		echo "To copy APK to host:"; \
		echo "  docker cp $(CONTAINER):$(DOCKER_WORKDIR)/examples/android-integration/app/build/outputs/apk/debug/app-debug.apk ./"; \
		echo ""; \
	else \
		echo ""; \
		echo "✗ Android example build failed - see error output above"; \
		exit 1; \
	fi

# Build and install Android example app on device
android-example-install: docker-check-running
	@echo ""
	@echo "=========================================="
	@echo "Building and installing Android example..."
	@echo "=========================================="
	@# Sync the example project to the container
	@docker exec $(CONTAINER) mkdir -p $(DOCKER_WORKDIR)/examples/android-integration
	@docker cp $(ROOT_DIR)/examples/android-integration/. $(CONTAINER):$(DOCKER_WORKDIR)/examples/android-integration/
	@# Set up local.properties for Android SDK
	@echo "sdk.dir=/opt/android-sdk" > $(ROOT_DIR)/examples/android-integration/local.properties
	@docker cp $(ROOT_DIR)/examples/android-integration/local.properties $(CONTAINER):$(DOCKER_WORKDIR)/examples/android-integration/local.properties
	@# Build and install the app
	@echo "NOTE: This requires an Android device or emulator connected via ADB"
	@echo "      Make sure ADB is accessible from the container"
	@echo ""
	@if docker exec $(CONTAINER) bash -c "cd $(DOCKER_WORKDIR)/examples/android-integration && ./gradlew installDebug" 2>&1; then \
		echo ""; \
		echo "✓ Android example app installed successfully!"; \
		echo "  App package: com.example.rgss"; \
		echo ""; \
		echo "To launch the app from command line:"; \
		echo "  adb shell am start -n com.example.rgss/.MainActivity"; \
		echo ""; \
	else \
		echo ""; \
		echo "✗ Android example installation failed"; \
		echo "  Make sure an Android device/emulator is connected"; \
		echo "  Check ADB connectivity: adb devices"; \
		exit 1; \
	fi

# Alias for android-example-install
android-example: android-example-install

# Clean targets in Docker
clean: docker-init
	@echo "Cleaning build artifacts (Docker mode)..."
	@set -e; \
	abis=($(TOOLCHAIN_ABI_LIST)); \
	for i in $${!abis[@]}; do \
		abi=$${abis[$$i]}; \
		if [ $(TOOLCHAIN_COUNT) -eq 1 ]; then \
			build_dir=$(DOCKER_BUILD_DIR); \
		else \
			build_dir=$(DOCKER_BUILD_DIR)-$$abi; \
		fi; \
		docker exec $(CONTAINER) cmake --build $$build_dir --target clean 2>/dev/null || true; \
	done

clean-libs: docker-init
	@echo "Cleaning library builds (Docker mode)..."
	@set -e; \
	abis=($(TOOLCHAIN_ABI_LIST)); \
	for i in $${!abis[@]}; do \
		abi=$${abis[$$i]}; \
		if [ $(TOOLCHAIN_COUNT) -eq 1 ]; then \
			build_dir=$(DOCKER_BUILD_DIR); \
		else \
			build_dir=$(DOCKER_BUILD_DIR)-$$abi; \
		fi; \
		docker exec $(CONTAINER) cmake --build $$build_dir --target clean-libs 2>/dev/null || true; \
	done

clean-downloads: docker-init
	@echo "Cleaning downloads (Docker mode)..."
	@set -e; \
	abis=($(TOOLCHAIN_ABI_LIST)); \
	for i in $${!abis[@]}; do \
		abi=$${abis[$$i]}; \
		if [ $(TOOLCHAIN_COUNT) -eq 1 ]; then \
